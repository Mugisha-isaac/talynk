// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  username       String    @unique
  passwordHash   String
  userType       UserType  @default(AUDIENCE)
  profilePicture String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  creator        Creator?
  audienceMember AudienceMember?

  @@map("users")
}

enum UserType {
  CREATOR
  AUDIENCE
  ADMIN
}

model Creator {
  id                     String     @id @default(cuid())
  user                   User       @relation(fields: [userId], references: [id])
  userId                 String     @unique
  bio                    String?
  discipline             Discipline
  gender                 String?
  location               String?
  followerCount          Int        @default(0)
  visibilityScoreCurrent Float      @default(0)
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  contentItems     ContentItem[]
  visibilityScores VisibilityScore[]
  followers        Follow[]          @relation("CreatorFollowers")

  @@map("creators")
}

enum Discipline {
  MUSIC
  VISUAL_ARTS
  COMEDY
  ATHLETICS
  PERFORMING_ARTS
}

model AudienceMember {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id])
  userId      String   @unique
  preferences Json?
  createdAt   DateTime @default(now())

  follows         Follow[]         @relation("AudienceFollows")
  interactions    Interaction[]
  recommendations Recommendation[]

  @@map("audience_members")
}

model Follow {
  id         String         @id @default(cuid())
  follower   AudienceMember @relation("AudienceFollows", fields: [followerId], references: [id])
  followerId String
  creator    Creator        @relation("CreatorFollowers", fields: [creatorId], references: [id])
  creatorId  String
  createdAt  DateTime       @default(now())

  @@unique([followerId, creatorId])
  @@map("follows")
}

model ContentItem {
  id                 String        @id @default(cuid())
  creator            Creator       @relation(fields: [creatorId], references: [id])
  creatorId          String
  title              String
  description        String?
  contentType        ContentType
  discipline         Discipline
  mediaUrl           String
  cloudinaryPublicId String?
  uploadDate         DateTime      @default(now())
  status             ContentStatus @default(PROCESSING)

  qualityScore    QualityScore?
  interactions    Interaction[]
  recommendations Recommendation[]

  @@map("content_items")
}

enum ContentType {
  AUDIO
  VIDEO
  IMAGE
}

enum ContentStatus {
  PROCESSING
  PUBLISHED
  REJECTED
  FLAGGED
}

model QualityScore {
  id                   String      @id @default(cuid())
  contentItem          ContentItem @relation(fields: [contentItemId], references: [id])
  contentItemId        String      @unique
  technicalQuality     Float
  structuralCoherence  Float
  originality          Float
  genreAppropriateness Float
  accessibility        Float
  overallScore         Float
  assessedAt           DateTime    @default(now())

  @@map("quality_scores")
}

model Interaction {
  id               String          @id @default(cuid())
  audienceMember   AudienceMember  @relation(fields: [audienceMemberId], references: [id])
  audienceMemberId String
  contentItem      ContentItem     @relation(fields: [contentItemId], references: [id])
  contentItemId    String
  interactionType  InteractionType
  sessionDuration  Int?
  timestamp        DateTime        @default(now())

  @@map("interactions")
}

enum InteractionType {
  VIEW
  LIKE
  SHARE
  COMMENT
  FOLLOW
}

model Recommendation {
  id               String         @id @default(cuid())
  audienceMember   AudienceMember @relation(fields: [audienceMemberId], references: [id])
  audienceMemberId String
  contentItem      ContentItem    @relation(fields: [contentItemId], references: [id])
  contentItemId    String
  score            Float
  rankPosition     Int
  algorithm        String // e.g. "lightgcn", "content-based", "hybrid"
  generatedAt      DateTime       @default(now())

  @@map("recommendations")
}

model VisibilityScore {
  id                 String   @id @default(cuid())
  creator            Creator  @relation(fields: [creatorId], references: [id])
  creatorId          String
  engagementScore    Float
  qualityScore       Float
  fairnessAdjustment Float
  finalScore         Float
  calculatedAt       DateTime @default(now())

  @@map("visibility_scores")
}
