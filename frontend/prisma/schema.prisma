// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  name          String?
  avatarUrl     String?
  bannerUrl     String?
  role          UserRole   @default(TALENT)
  verified      Boolean    @default(false)
  verifiedAt    DateTime?
  talent        Talent?
  sponsor       Sponsor?

  followers     UserFollow[] @relation("followers")
  following     UserFollow[] @relation("following")

  engagements   Engagement[]
  notifications Notification[]
  messages      Message[]
  savedMedia    SavedMedia[]
  achievements  UserAchievement[]
  
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([email])
  @@index([role])
}

enum UserRole {
  TALENT
  SPONSOR
  ADMIN
  MODERATOR
  FAN
}

model UserFollow {
  id          String   @id @default(cuid())
  followerId  String
  follower    User     @relation("following", fields: [followerId], references: [id], onDelete: Cascade)
  
  followingId String
  following   User     @relation("followers", fields: [followingId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  
  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Talent {
  id            String     @id @default(cuid())
  userId        String     @unique
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  bio           String?
  location      String?
  website       String?
  socialLinks   Json?
  categories    String[]
  skills        String[]
  visibilityScore AIVisibilityScore?
  analytics     Analytics[]
  media         Media[]
  matchedWith   Recommendation[] @relation("talentRecommendations")
  
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([userId])
}

model AIVisibilityScore {
  id            String   @id @default(cuid())
  talentId      String   @unique
  talent        Talent   @relation(fields: [talentId], references: [id], onDelete: Cascade)
  
  score         Float
  reason        String
  factors       Json?
  
  lastUpdated   DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([score])
}
model Sponsor {
  id            String     @id @default(cuid())
  userId        String     @unique
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  companyName   String
  description   String?
  logo          String?
  website       String?
  location      String?
  
  sectors       String[]
  preferences   Json?
  
  recommendations Recommendation[] @relation("sponsorRecommendations")
  
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([userId])
}

model Sector {
  id            String     @id @default(cuid())
  name          String     @unique
  slug          String     @unique
  description   String?
  icon          String? 
  color         String? 
  
  media         Media[]
  
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Media {
  id            String     @id @default(cuid())
  talentId      String
  talent        Talent     @relation(fields: [talentId], references: [id], onDelete: Cascade)
  
  title         String
  description   String?
  type          MediaType
  fileUrl       String
  thumbnailUrl  String?
  duration      Int?  
  
  sectorId      String
  sector        Sector     @relation(fields: [sectorId], references: [id])
  aiTags        String[] 
  aiCaption     String? 
  classification Json?
  confidenceScore Float?
  engagements   Engagement[]
  recommendations Recommendation[] @relation("mediaRecommendations")
  savedBy       SavedMedia[]
  isPublic      Boolean    @default(true)
  
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([talentId])
  @@index([sectorId])
  @@index([createdAt])
}

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
}
model Engagement {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  mediaId     String
  media       Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  
  type        EngagementType
  content     String?
  
  createdAt   DateTime @default(now())
  
  @@unique([userId, mediaId, type])
  @@index([userId])
  @@index([mediaId])
  @@index([type])
}

enum EngagementType {
  LIKE
  COMMENT
  SHARE
  SAVE
}

model Recommendation {
  id            String     @id @default(cuid())
  
  talentId      String
  talent        Talent     @relation("talentRecommendations", fields: [talentId], references: [id], onDelete: Cascade)
  
  sponsorId     String
  sponsor       Sponsor    @relation("sponsorRecommendations", fields: [sponsorId], references: [id], onDelete: Cascade)
  
  mediaId       String
  media         Media      @relation("mediaRecommendations", fields: [mediaId], references: [id], onDelete: Cascade)
  
  matchScore    Float      // 0-100: How well the talent matches sponsor's interests
  reason        String?    // Why this recommendation
  status        RecommendationStatus @default(PENDING)
  
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([talentId, sponsorId, mediaId])
  @@index([talentId])
  @@index([sponsorId])
  @@index([mediaId])
  @@index([matchScore])
}

enum RecommendationStatus {
  PENDING
  VIEWED
  INTERESTED
  REJECTED
  CONNECTED
}

// ============= ANALYTICS & METRICS =============
model Analytics {
  id          String   @id @default(cuid())
  talentId    String
  talent      Talent   @relation(fields: [talentId], references: [id], onDelete: Cascade)
  
  date        DateTime @db.Date
  views       Int      @default(0)
  likes       Int      @default(0)
  comments    Int      @default(0)
  shares      Int      @default(0)
  saves       Int      @default(0)
  followers   Int      @default(0)
  
  createdAt   DateTime @default(now())
  
  @@unique([talentId, date])
  @@index([talentId])
  @@index([date])
}

// ============= NOTIFICATIONS & MESSAGING =============
model Notification {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type        NotificationType
  title       String
  message     String
  actionUrl   String?
  read        Boolean  @default(false)
  
  createdAt   DateTime @default(now())
  
  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

enum NotificationType {
  NEW_FOLLOWER
  LIKE
  COMMENT
  SHARE
  RECOMMENDATION
  MESSAGE
  ACHIEVEMENT
  SYSTEM
}

model Message {
  id          String   @id @default(cuid())
  
  senderId    String
  sender      User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  
  conversationId String
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  content     String
  read        Boolean  @default(false)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([senderId])
  @@index([conversationId])
  @@index([read])
}

model Conversation {
  id          String   @id @default(cuid())
  participantIds String[]  // User IDs of participants
  
  messages    Message[]
  
  lastMessageAt DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([participantIds])
}

// ============= MODERATION & REPORTING =============
model Report {
  id          String   @id @default(cuid())
  
  reportedBy  String
  
  type        ReportType
  targetId    String   // Media ID or User ID
  targetType  String   // "MEDIA" or "USER"
  
  reason      String
  description String?
  
  status      ReportStatus @default(PENDING)
  reviewedBy  String?
  reviewedAt  DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([targetId])
  @@index([createdAt])
}

enum ReportType {
  SPAM
  INAPPROPRIATE_CONTENT
  HARASSMENT
  COPYRIGHT
  MISLEADING
  OTHER
}

enum ReportStatus {
  PENDING
  UNDER_REVIEW
  DISMISSED
  ACTION_TAKEN
}

// ============= FEATURED & TRENDING =============
model FeaturedCreator {
  id            String   @id @default(cuid())
  talentId      String   @unique
  talent        Talent   @relation(fields: [talentId], references: [id], onDelete: Cascade)
  
  featuredAt    DateTime @default(now())
  expiresAt     DateTime?
  priority      Int      @default(0) // Higher = more prominent
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([featuredAt])
  @@index([priority])
}

model TrendingInsight {
  id            String   @id @default(cuid())
  
  type          String   // "CATEGORY", "HASHTAG", "CREATOR", "SOUND"
  name          String
  slug          String   @unique
  
  viewCount     Int      @default(0)
  engagementScore Float @default(0)
  momentum      Float    @default(0) // 0-100, growth rate
  
  category      String?  // For categorized trending
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([type])
  @@index([momentum])
  @@index([updatedAt])
}

model SavedMedia {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  mediaId     String
  media       Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  
  @@unique([userId, mediaId])
  @@index([userId])
}

// ============= ACHIEVEMENT & BADGES =============
model Achievement {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  icon        String?  // Icon name or emoji
  
  criteria    String   // JSON: {type: "follower_count", threshold: 1000}
  
  createdAt   DateTime @default(now())

  @@index([slug])
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  
  unlockedAt    DateTime @default(now())

  @@unique([userId, achievementId])
  @@index([userId])
}
